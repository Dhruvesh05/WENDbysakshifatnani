# Public API base URL used by the admin frontend in browser calls
NEXT_PUBLIC_API_URL=https://wendbysakshifatnani-edtn.onrender.com

# Admin auth
AUTH_SECRET=replace_with_a_long_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password

# Supabase (server-side only)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
SUPABASE_STORAGE_BUCKET=wend-media

# CORS origins allowed to call /api endpoints (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://wendbysakshifatnani.vercel.app

# SMTP for contact notification emails (server-side only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_IP_FAMILY=4
SMTP_USER=your_email@gmail.com
SMTP_PASS=replace_with_app_password
SMTP_FROM_EMAIL="WEND Contact <your_email@gmail.com>"
CONTACT_RECEIVER_EMAIL=your_email@gmail.com
