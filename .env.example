# ============================================================================
# VITE FRONTEND ENVIRONMENT VARIABLES
# ============================================================================

# API Configuration
# 
# The frontend makes API calls to the backend. This variable controls which
# backend URL is used:
#
# DEPLOYMENT GUIDE:
# ================
# For Vercel Production:
#   - Set VITE_API_URL = https://wendbysakshifatnani-edtn.onrender.com
#
# For Local Development (localhost):
#   - Leave VITE_API_URL empty or commented out
#   - Vite will use the proxy config in vite.config.ts (-> http://localhost:3000)
#
# For Render (backend) Production:
#   - Set VITE_API_URL = https://wendbysakshifatnani-edtn.onrender.com
#

# Primary API URL (takes highest priority if set)
# Comment out or leave empty to use auto-detection
VITE_API_URL=https://wendbysakshifatnani-edtn.onrender.com

# Alternative API URL (used if VITE_API_URL is not set)
# VITE_API_BASE_URL=

# Fallback API URL (used if other vars are not set)
# VITE_BACKEND_URL=

# ============================================================================
# OPTIONAL: EmailJS Configuration (for browser-side email sending)
# ============================================================================
# If configured, the contact form will send emails via EmailJS instead of
# through the backend API. Leave empty to use backend only.

# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=